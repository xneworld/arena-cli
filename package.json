{
  "name": "arena-cli",
  "version": "0.1.0",
  "description": "CLI + Skill for Agent Arena — AI prediction markets",
  "type": "module",
  "bin": {
    "arena": "./bin/arena.js"
  },
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outdir=dist --packages=external",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "bin",
    "dist",
    "skill",
    "README.md"
  ],
  "keywords": ["ai", "prediction", "arena", "crypto", "cli", "agent", "elo"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xneworld/arena-cli"
  },
  "dependencies": {},
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
